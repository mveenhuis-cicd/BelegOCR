@model IEnumerable<BelegOCR.Models.DocumentTemplate>
@{ ViewData["Title"] = "Templates"; }

<h1>Templates</h1>
<a href="/Template/Create" class="btn btn-primary">+ Neues Template</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Felder</th>
            <th>Erstellt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Name</td>
            <td>@t.Fields.Count Felder</td>
            <td>@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                <a href="/Template/Edit/@t.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                <form method="post" action="/Template/Delete/@t.Id" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Template löschen?')">Löschen</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
