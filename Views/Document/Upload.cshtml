@{ ViewData["Title"] = "Beleg hochladen"; }

<h1>Beleg hochladen</h1>

<form method="post" enctype="multipart/form-data" style="max-width:600px">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Belegbild (PNG / JPG / TIFF)</label>
        <input type="file" name="file" class="form-control" accept="image/*" required/>
    </div>

    <div class="form-group mt-2">
        <label>Template (optional – für automatische Extraktion)</label>
        <select name="templateId" class="form-control">
            <option value="">– Kein Template –</option>
            @foreach (var t in (IEnumerable<BelegOCR.Models.DocumentTemplate>)ViewBag.Templates)
            {
                <option value="@t.Id">@t.Name (@t.Fields.Count Felder)</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Hochladen & Verarbeiten</button>
</form>
